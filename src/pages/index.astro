---
const name = "Roman Tikhonov";
const bio = "Placeholder bio. Something short about what I do will go here.";
const links = [
	{ label: "Email", href: "mailto:hello@rtikhonov.com" },
	{ label: "GitHub", href: "https://github.com/rtikhonov" },
	{ label: "LinkedIn", href: "https://www.linkedin.com/in/rtikhonov" },
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={`${name} — personal website`} />
		<meta name="generator" content={Astro.generator} />
		<title>{name}</title>
	</head>
	<body>
		<main>
			<h1>{name}</h1>
			<p>{bio}</p>
			<nav>
				{
					links.map((link) => (
						<a href={link.href}>{link.label}</a>
					))
				}
			</nav>
		</main>
	</body>
</html>

<style is:global>
	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	:root {
		color-scheme: light dark;
		--bg: #fafafa;
		--fg: #111;
		--muted: #555;
		--link: #111;
		--link-hover: #555;
	}

	@media (prefers-color-scheme: dark) {
		:root {
			--bg: #111;
			--fg: #f5f5f5;
			--muted: #aaa;
			--link: #f5f5f5;
			--link-hover: #aaa;
		}
	}

	html {
		font-family:
			system-ui,
			-apple-system,
			BlinkMacSystemFont,
			"Segoe UI",
			Roboto,
			Helvetica,
			Arial,
			sans-serif;
		line-height: 1.5;
		background: var(--bg);
		color: var(--fg);
	}

	body {
		margin: 0;
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem;
	}

	main {
		max-width: 28rem;
		width: 100%;
	}

	h1 {
		font-size: 1.75rem;
		font-weight: 600;
		letter-spacing: -0.02em;
		margin: 0 0 0.75rem;
	}

	p {
		margin: 0 0 1.5rem;
		color: var(--muted);
	}

	nav {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}

	nav a {
		color: var(--link);
		text-decoration: underline;
		text-underline-offset: 0.2em;
	}

	nav a:hover {
		color: var(--link-hover);
	}
</style>
