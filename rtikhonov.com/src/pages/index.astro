---
import { Image } from "astro:assets";
import linkedinIcon from "@tabler/icons/outline/brand-linkedin.svg?raw";
import telegramIcon from "@tabler/icons/outline/brand-telegram.svg?raw";
import ProjectsGallery from "../components/ProjectsGallery.astro";
import portrait from "../assets/roman.png";

const name = "Roman Tikhonov";
const bio =
	"Product Manager leading Onboarding and Identity at payme (TBC Uzbekistan), a payment app with millions of users. Former cognitive science researcher at Carnegie Mellon with a PhD in Cognitive Psychology from St. Petersburg University.";

/** Tabler Icons (MIT) — https://tabler.io/icons
 *  Contact hrefs are base64-obfuscated so static scrapers / LLM crawls
 *  do not see clear URLs; humans get them via a tiny client script.
 */
const links = [
	{
		label: "LinkedIn",
		hrefEnc: Buffer.from(
			"https://www.linkedin.com/in/romantikhonov/",
			"utf8",
		).toString("base64"),
		icon: linkedinIcon,
	},
	{
		label: "Telegram",
		hrefEnc: Buffer.from("https://t.me/rvtikhonov", "utf8").toString(
			"base64",
		),
		icon: telegramIcon,
	},
];

const timeline = [
	{
		year: "2026-04",
		text: "Mentored teams at the Cursor hackathon (TBC Uzbekistan / payme). Helped choose and validate product ideas.",
	},
	{
		year: "2025",
		text: "Joined payme (TBC Uzbekistan) as Product Owner, later Product Manager. Own Onboarding and Identity. Tashkent.",
	},
	{
		year: "2024",
		text: "Co-founded ReviewLab.app, a product feedback platform. Shipped MVP in 2.5 months.",
	},
	{
		year: "2023-11",
		text: "Published in MIT's Open Mind: Prediction, Explanation, and Control — mental models in dynamic environments.",
	},
	{
		year: "2023",
		text: "Moved into product management: PM at HumanteQ (mental health tech).",
	},
	{
		year: "2022",
		text: "Postdoctoral Fellow at Carnegie Mellon University, Pittsburgh. Studied how people learn complex patterns.",
	},
	{
		year: "2021",
		text: 'Researcher at JetBrains Research. PhD in Psychology, St. Petersburg University. "Best Teacher" award at HSE University.',
	},
	{
		year: "2018",
		text: "Lecturer, then Senior Lecturer at HSE University, St. Petersburg. Designed 4 award-winning courses.",
	},
	{
		year: "2016",
		text: "Market Research Analyst at UsabilityLab: ranked 700+ features across 16 mobile banking apps.",
	},
	{
		year: "2015",
		text: "Master's in Cognitive Psychology (with distinction). Started 7 years as a researcher at St. Petersburg University; co-authored 20+ peer-reviewed papers.",
	},
	{
		year: "2013",
		text: "Bachelor's in Psychology, St. Petersburg University.",
	},
	{
		year: "2012",
		text: "Exchange semester at the University of Eastern Finland.",
	},
	{
		year: "2010",
		text: "Led a human rights education project at AIESEC with 14 international volunteers.",
	},
	{
		year: "2009",
		text: "Finished vocational training in web development; started studying psychology.",
	},
	{
		year: "1992-05",
		text: "Born in Kryvyi Rih, Ukraine.",
	},
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={`${name} — personal website`} />
		<meta name="generator" content={Astro.generator} />
		<title>{name}</title>
	</head>
	<body>
		<main>
			<header>
				<Image
					src={portrait}
					alt={`${name} portrait`}
					width={140}
					height={140}
					quality={85}
					class="portrait"
					data-tilt
				/>
				<h1>{name}</h1>
				<p class="bio">{bio}</p>
				<nav data-nosnippet aria-label="Contact">
					{
						links.map((link) => (
							<a
								href="#"
								data-u={link.hrefEnc}
								rel="nofollow noopener noreferrer"
								class="contact-link"
							>
								<span
									class="nav-icon"
									aria-hidden="true"
									set:html={link.icon}
								/>
								{link.label}
							</a>
						))
					}
				</nav>
				<script is:inline>
					(() => {
						const reveal = (a) => {
							const enc = a.getAttribute("data-u");
							if (!enc) return;
							try {
								a.href = atob(enc);
							} catch {
								/* ignore */
							}
						};
						document.querySelectorAll("a.contact-link[data-u]").forEach((a) => {
							a.addEventListener("pointerdown", () => reveal(a), {
								once: true,
							});
							a.addEventListener("focus", () => reveal(a), { once: true });
							a.addEventListener(
								"click",
								(e) => {
									reveal(a);
									if (a.getAttribute("href") === "#") {
										e.preventDefault();
									} else {
										a.setAttribute("target", "_blank");
									}
								},
								{ once: true },
							);
						});
					})();
				</script>
			</header>

			<ProjectsGallery />

			<section class="timeline" aria-label="Timeline">
				<ol>
					{
						timeline.map((entry) => (
							<li>
								<span class="year">{entry.year}</span>
								<span class="event">{entry.text}</span>
							</li>
						))
					}
				</ol>
			</section>
		</main>
		<script>
			import "../scripts/tilt";
		</script>
	</body>
</html>

<style is:global>
	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	:root {
		color-scheme: light dark;
		--bg: #fafafa;
		--fg: #111;
		--muted: #555;
		--border: #ddd;
		--link: #111;
		--link-hover: #555;
		--accent: #e35d05;
		--accent-fg: #fff;
		--font-mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
	}

	@media (prefers-color-scheme: dark) {
		:root {
			--bg: #111;
			--fg: #f5f5f5;
			--muted: #aaa;
			--border: #333;
			--link: #f5f5f5;
			--link-hover: #aaa;
			--accent: #f59a56;
			--accent-fg: #111;
		}
	}

	html {
		font-family:
			system-ui,
			-apple-system,
			BlinkMacSystemFont,
			"Segoe UI",
			Roboto,
			Helvetica,
			Arial,
			sans-serif;
		line-height: 1.5;
		background: var(--bg);
		color: var(--fg);
		overflow-x: clip;
	}

	body {
		margin: 0;
		min-height: 100vh;
		display: flex;
		justify-content: center;
		padding: 3rem 1.5rem;
		overflow-x: clip;
	}

	main {
		max-width: 38rem;
		width: 100%;
	}

	header {
		margin-bottom: 3rem;
		perspective: 800px;
	}

	.portrait {
		display: block;
		width: 140px;
		height: 140px;
		border-radius: 50%;
		object-fit: cover;
		margin: 0 0 1.25rem;
		transform-style: preserve-3d;
	}

	h1 {
		font-size: 2.4rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		margin: 0 0 0.75rem;
	}

	.bio {
		margin: 0 0 1.5rem;
		color: var(--muted);
	}

	nav {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}

	nav a {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 0.2em;
	}

	nav a:hover {
		color: color-mix(in srgb, var(--accent) 70%, var(--fg));
	}

	.nav-icon {
		display: inline-flex;
		width: 1.1em;
		height: 1.1em;
		flex-shrink: 0;
		color: var(--muted);
	}

	.nav-icon :global(svg) {
		width: 100%;
		height: 100%;
		display: block;
	}

	.timeline ol {
		list-style: none;
		margin: 0;
		padding: 0;
		border-left: 1px solid var(--border);
	}

	.timeline li {
		display: grid;
		grid-template-columns: 5.5rem 1fr;
		gap: 1rem;
		padding: 0 0 1.25rem 1.25rem;
		position: relative;
	}

	.timeline li:last-child {
		padding-bottom: 0;
	}

	.timeline li::before {
		content: "";
		position: absolute;
		left: -3.5px;
		top: 0.55em;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--accent);
	}

	.year {
		font-family: var(--font-mono);
		font-variant-numeric: tabular-nums;
		font-size: 0.875rem;
		color: var(--muted);
		line-height: 1.5;
	}

	.event {
		font-size: 0.95rem;
		line-height: 1.5;
	}

	@media (max-width: 480px) {
		.timeline li {
			grid-template-columns: 1fr;
			gap: 0.25rem;
		}
	}
</style>
