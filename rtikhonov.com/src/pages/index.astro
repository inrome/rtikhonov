---
import { Image } from "astro:assets";
import videoIcon from "@tabler/icons/outline/video.svg?raw";
import linkedinIcon from "@tabler/icons/outline/brand-linkedin.svg?raw";
import telegramIcon from "@tabler/icons/outline/brand-telegram.svg?raw";
import ProjectsGallery from "../components/ProjectsGallery.astro";
import {
	formatTimelineDate,
	timelineDateTime,
} from "../lib/format-timeline-date";
import {
	timeline,
	yearOverviews,
	type TimelineEntry,
} from "../data/timeline";
import portrait from "../assets/roman.jpg";

function isSvgMarker(marker: string): boolean {
	return marker.trimStart().startsWith("<svg");
}

const name = "Roman Tikhonov";
const bioLines = [
	"Product Manager leading Onboarding and Identity at payme (TBC Uzbekistan).",
	"Former cognitive science researcher at Carnegie Mellon with a PhD from St. Petersburg University.",
];
const bio = bioLines.join(" ");
const description = `${name} — ${bio}`;
const canonicalUrl = new URL("/", Astro.site).href;
// Dedicated public asset so social crawlers are not blocked by the
// portrait AI-training opt-out on `/_astro/roman*`.
const ogImageUrl = new URL("/og.jpg", Astro.site).href;
const ogImageAlt = `${name} portrait`;

/** Tabler Icons (MIT) — https://tabler.io/icons
 *  Contact hrefs and handles are base64-obfuscated so static scrapers /
 *  LLM crawls do not see clear URLs or handles; humans get them via a
 *  tiny client script.
 *  Call is first (primary CTA); LinkedIn / Telegram stay secondary.
 */
const links = [
	{
		prefix: undefined as string | undefined,
		label: "15 min call",
		labelEnc: undefined as string | undefined,
		hrefEnc: Buffer.from("https://cal.com/tikhonov/15-min-chat", "utf8").toString(
			"base64",
		),
		icon: videoIcon,
		primary: true,
	},
	{
		prefix: "LinkedIn:",
		label: "LinkedIn",
		labelEnc: Buffer.from("/in/romantikhonov", "utf8").toString("base64"),
		hrefEnc: Buffer.from(
			"https://www.linkedin.com/in/romantikhonov/",
			"utf8",
		).toString("base64"),
		icon: linkedinIcon,
		primary: false,
	},
	{
		prefix: "Telegram:",
		label: "Telegram",
		labelEnc: Buffer.from("@rvtikhonov", "utf8").toString("base64"),
		hrefEnc: Buffer.from("https://t.me/rvtikhonov", "utf8").toString(
			"base64",
		),
		icon: telegramIcon,
		primary: false,
	},
];

type YearGroup = { year: string; entries: TimelineEntry[] };

const timelineByYear: YearGroup[] = [];
for (const entry of timeline) {
	const year = entry.date.slice(0, 4);
	const last = timelineByYear[timelineByYear.length - 1];
	if (last && last.year === year) {
		last.entries.push(entry);
	} else {
		timelineByYear.push({ year, entries: [entry] });
	}
}

type EraId = "product" | "research" | "undergrad" | "earlier";

function eraForYear(year: string): EraId {
	const n = Number(year);
	if (n >= 2023) return "product";
	if (n >= 2014) return "research";
	if (n >= 2009 && n <= 2013) return "undergrad";
	return "earlier";
}

const eras: {
	id: EraId;
	title: string;
	open: boolean;
	years: YearGroup[];
}[] = [
	{ id: "product", title: "Product", open: true, years: [] },
	{ id: "research", title: "Academia", open: false, years: [] },
	{ id: "undergrad", title: "Undergrad", open: false, years: [] },
	{ id: "earlier", title: "Earlier", open: false, years: [] },
];

for (const group of timelineByYear) {
	const era = eras.find((e) => e.id === eraForYear(group.year));
	if (era) era.years.push(group);
}
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta
			name="theme-color"
			content="#fafafa"
			media="(prefers-color-scheme: light)"
		/>
		<meta
			name="theme-color"
			content="#111"
			media="(prefers-color-scheme: dark)"
		/>
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:title" content={name} />
		<meta property="og:description" content={bio} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:alt" content={ogImageAlt} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={name} />
		<meta name="twitter:description" content={bio} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="twitter:image:alt" content={ogImageAlt} />
		<meta name="generator" content={Astro.generator} />
		<title>{name}</title>
	</head>
	<body>
		<main>
			<header>
				<span class="portrait-frame">
					<Image
						src={portrait}
						alt={ogImageAlt}
						width={140}
						height={140}
						densities={[1, 2, 3]}
						quality={90}
						class="portrait"
					/>
				</span>
				<h1>{name}</h1>
				{
					bioLines.map((line) => (
						<p class="bio">{line}</p>
					))
				}
				<nav id="contact" data-nosnippet aria-label="Contact">
					{
						links.map((link) => (
							<a
								href="#"
								data-u={link.hrefEnc}
								data-l={link.labelEnc}
								rel="nofollow noopener noreferrer"
								class:list={[
									"contact-item",
									"contact-link",
									link.primary && "contact-link--primary",
								]}
							>
								<span
									class="nav-icon"
									aria-hidden="true"
									set:html={link.icon}
								/>
								{link.prefix && (
									<span class="contact-prefix">{link.prefix}</span>
								)}
								<span class="contact-link__label">{link.label}</span>
							</a>
						))
					}
				</nav>
				<script is:inline>
					(() => {
						const revealHref = (a) => {
							const enc = a.getAttribute("data-u");
							if (!enc) return;
							try {
								a.href = atob(enc);
							} catch {
								/* ignore */
							}
						};
						document.querySelectorAll("a.contact-link").forEach((a) => {
							const labelEnc = a.getAttribute("data-l");
							const labelEl = a.querySelector(".contact-link__label");
							if (labelEnc && labelEl) {
								try {
									labelEl.textContent = atob(labelEnc);
								} catch {
									/* ignore */
								}
							}
							a.addEventListener("pointerdown", () => revealHref(a), {
								once: true,
							});
							a.addEventListener("focus", () => revealHref(a), { once: true });
							a.addEventListener(
								"click",
								(e) => {
									revealHref(a);
									if (a.getAttribute("href") === "#") {
										e.preventDefault();
									} else {
										a.setAttribute("target", "_blank");
									}
								},
								{ once: true },
							);
						});
					})();
				</script>
			</header>

			<ProjectsGallery />

			<section class="timeline" id="timeline" aria-label="Timeline">
				<h2 class="section-title">Timeline</h2>
				{
					eras.map((era) => (
						<details class="timeline-era" open={era.open || undefined}>
							<summary class="timeline-era__summary">
								<span class="timeline-era__title">{era.title}</span>
								<span class="chevron" aria-hidden="true" />
							</summary>
							<ol>
								{era.years.map((group) => {
									if (group.entries.length === 1) {
										const entry = group.entries[0];
										const label = formatTimelineDate(entry.date);
										const datetime = timelineDateTime(entry.date);
										return (
											<li id={entry.id}>
												<span class="year">
													{datetime ? (
														<time datetime={datetime}>{label}</time>
													) : (
														label
													)}
												</span>
												<span class="event">
													{entry.marker &&
														(isSvgMarker(entry.marker) ? (
															<span
																class="event-marker event-marker--icon"
																aria-hidden="true"
																set:html={entry.marker}
															/>
														) : (
															<span class="event-marker" aria-hidden="true">
																{entry.marker}
															</span>
														))}
													{entry.href ? (
														<a class="event-link" href={entry.href}>
															{entry.text}
														</a>
													) : (
														entry.text
													)}
												</span>
											</li>
										);
									}

									const overview =
										yearOverviews[group.year] ??
										group.entries.map((e) => e.text).join(" ");
									return (
										<li class="year-group">
											<details>
												<summary>
													<span class="year">
														<time datetime={group.year}>{group.year}</time>
													</span>
													<span class="event overview">
														{overview}
														<span class="chevron" aria-hidden="true" />
													</span>
												</summary>
												<ol>
													{group.entries.map((entry) => {
														const datetime = timelineDateTime(entry.date);
														/* Year-only rows under the same year header
														   repeat the parent label — show an em dash. */
														const label =
															entry.date === group.year
																? "—"
																: formatTimelineDate(entry.date);
														return (
															<li id={entry.id}>
																<span class="year">
																	{datetime ? (
																		<time datetime={datetime}>{label}</time>
																	) : (
																		label
																	)}
																</span>
																<span class="event">
																	{entry.marker &&
																		(isSvgMarker(entry.marker) ? (
																			<span
																				class="event-marker event-marker--icon"
																				aria-hidden="true"
																				set:html={entry.marker}
																			/>
																		) : (
																			<span
																				class="event-marker"
																				aria-hidden="true"
																			>
																				{entry.marker}
																			</span>
																		))}
																	{entry.href ? (
																		<a class="event-link" href={entry.href}>
																			{entry.text}
																		</a>
																	) : (
																		entry.text
																	)}
																</span>
															</li>
														);
													})}
												</ol>
											</details>
										</li>
									);
								})}
							</ol>
						</details>
					))
				}
			</section>
		</main>
	</body>
</html>

<style is:global>
	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	:root {
		color-scheme: light dark;
		--bg: #fafafa;
		--fg: #111;
		--muted: #555;
		--border: #ddd;
		--link: #111;
		--link-hover: #555;
		--accent: #e35d05;
		--accent-fg: #fff;
		--font-mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
	}

	@media (prefers-color-scheme: dark) {
		:root {
			--bg: #111;
			--fg: #f5f5f5;
			--muted: #aaa;
			--border: #333;
			--link: #f5f5f5;
			--link-hover: #aaa;
			--accent: #f59a56;
			--accent-fg: #111;
		}
	}

	html {
		font-family:
			system-ui,
			-apple-system,
			BlinkMacSystemFont,
			"Segoe UI",
			Roboto,
			Helvetica,
			Arial,
			sans-serif;
		line-height: 1.5;
		background: var(--bg);
		color: var(--fg);
		overflow-x: clip;
		scroll-behavior: smooth;
	}

	@media (prefers-reduced-motion: reduce) {
		html {
			scroll-behavior: auto;
		}
	}

	body {
		margin: 0;
		min-height: 100dvh;
		display: flex;
		justify-content: center;
		padding: 3rem 1.5rem;
		overflow-x: clip;
	}

	main {
		max-width: 38rem;
		width: 100%;
	}

	header {
		margin-bottom: 3rem;
	}

	.portrait-frame {
		display: block;
		position: relative;
		width: 140px;
		height: 140px;
		border-radius: 50%;
		clip-path: circle(50%);
		margin: 0 0 1.25rem;
		overflow: hidden;
		isolation: isolate;
	}

	/* Holographic sheen: a diagonal streak that sweeps down once per
	   hover. No cursor tracking, no glow. */
	.portrait-frame::before {
		content: "";
		position: absolute;
		inset: -60% 0;
		z-index: 1;
		pointer-events: none;
		opacity: 0;
		background: linear-gradient(
			115deg,
			transparent 38%,
			color-mix(in srgb, #fff 36%, transparent) 48%,
			color-mix(in srgb, var(--accent) 26%, transparent) 54%,
			transparent 64%
		);
		mix-blend-mode: soft-light;
		transform: translateY(-35%);
	}

	.portrait {
		display: block;
		width: 100%;
		height: 100%;
		border-radius: 50%;
		object-fit: cover;
		/* Zoom so the yellow backdrop fills the circle and the pink wall
		   edge (halo ring) leaves the frame */
		transform: scale(1.38);
		transform-origin: 50% 22%;
	}

	@media (hover: hover) and (pointer: fine) {
		.portrait-frame {
			transition: transform 250ms cubic-bezier(0.22, 1, 0.36, 1);
		}

		.portrait-frame:hover {
			transform: scale(1.03);
		}

		.portrait-frame:hover::before {
			animation: holo-sweep 700ms ease-out;
		}
	}

	@keyframes holo-sweep {
		0% {
			opacity: 0;
			transform: translateY(-35%);
		}
		35% {
			opacity: 1;
		}
		100% {
			opacity: 0;
			transform: translateY(35%);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.portrait-frame {
			transition: none;
		}

		.portrait-frame:hover {
			transform: none;
		}

		.portrait-frame:hover::before {
			animation: none;
		}
	}

	h1 {
		font-size: 2.4rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		margin: 0 0 0.75rem;
	}

	.bio {
		margin: 0 0 0.4rem;
		color: var(--muted);
	}

	.bio:last-of-type {
		margin-bottom: 1.5rem;
	}

	.section-title {
		margin: 0 0 1rem;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--muted);
		font-family: var(--font-mono);
	}

	#work,
	#timeline,
	#contact {
		scroll-margin-top: 1.25rem;
	}

	nav#contact {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 1rem;
	}

	.contact-item {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
	}

	.contact-prefix {
		color: var(--muted);
	}

	/* Prefix sheen: a diagonal highlight sweeps across the text once per
	   hover, echoing the portrait holo. Gradient is clipped to the glyphs. */
	@media (hover: hover) and (pointer: fine) {
		.contact-item:hover .contact-prefix {
			background: linear-gradient(
				115deg,
				var(--muted) 40%,
				color-mix(in srgb, #fff 45%, var(--muted)) 47%,
				color-mix(in srgb, var(--accent) 65%, var(--muted)) 53%,
				var(--muted) 60%
			);
			background-size: 300% 100%;
			background-position: 100% 0;
			-webkit-background-clip: text;
			background-clip: text;
			color: transparent;
			animation: prefix-sheen 700ms ease-out;
		}
	}

	@keyframes prefix-sheen {
		0% {
			background-position: 0% 0;
		}
		100% {
			background-position: 100% 0;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.contact-item:hover .contact-prefix {
			background: none;
			color: var(--muted);
			animation: none;
		}
	}

	/* The whole row is the anchor; only the label looks like a link. */
	nav#contact a {
		color: inherit;
		text-decoration: none;
		border-radius: 0.2rem;
	}

	nav#contact a:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 3px;
	}

	.contact-link__label {
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 0.2em;
		transition: color 150ms ease;
	}

	.contact-link--primary {
		padding: 0.35rem 0.85rem;
		background: transparent;
		color: var(--fg);
		border: 1px solid var(--border);
		border-radius: 999px;
		gap: 0.45rem;
		transition:
			color 150ms ease,
			border-color 150ms ease,
			background 150ms ease;
	}

	.contact-link--primary .nav-icon {
		color: var(--muted);
	}

	.contact-link--primary .contact-link__label {
		color: var(--fg);
		text-decoration: none;
		font-weight: 500;
	}

	.contact-link--primary:hover,
	.contact-link--primary:focus-visible {
		border-color: color-mix(in srgb, var(--accent) 55%, var(--border));
	}

	/* Same accent icon + label as LinkedIn / Telegram rows */
	.contact-link--primary:hover .nav-icon,
	.contact-link--primary:focus-visible .nav-icon {
		color: var(--accent);
	}

	.contact-link--primary:hover .contact-link__label,
	.contact-link--primary:focus-visible .contact-link__label {
		color: var(--accent);
	}

	.contact-item:not(.contact-link--primary) .contact-link__label {
		color: var(--muted);
		text-decoration: underline;
	}

	.contact-item:not(.contact-link--primary):hover .contact-link__label,
	.contact-item:not(.contact-link--primary):focus-visible .contact-link__label {
		color: var(--accent);
	}

	.nav-icon {
		display: inline-flex;
		width: 1.1em;
		height: 1.1em;
		flex-shrink: 0;
		color: var(--muted);
		transition: color 150ms ease;
	}

	.contact-item:hover .nav-icon,
	.contact-item:focus-visible .nav-icon {
		color: var(--accent);
	}

	.nav-icon svg {
		width: 100%;
		height: 100%;
		display: block;
	}

	.timeline {
		margin-top: 0.5rem;
	}

	.timeline-era {
		margin: 0 0 1.25rem;
	}

	.timeline-era:last-child {
		margin-bottom: 0;
	}

	.timeline-era__summary {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		cursor: pointer;
		list-style: none;
		margin: 0 0 0.85rem;
		padding: 0.15rem 0;
		border-radius: 0.2rem;
	}

	.timeline-era__summary::-webkit-details-marker {
		display: none;
	}

	.timeline-era__summary:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 3px;
	}

	.timeline-era__title {
		font-family: var(--font-mono);
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--fg);
	}

	.timeline-era__summary:hover .timeline-era__title,
	.timeline-era__summary:focus-visible .timeline-era__title {
		color: color-mix(in srgb, var(--accent) 55%, var(--fg));
	}

	.timeline-era[open] > .timeline-era__summary .timeline-era__title {
		color: color-mix(in srgb, var(--accent) 55%, var(--fg));
	}

	.timeline-era > .timeline-era__summary .chevron {
		flex-shrink: 0;
		width: 0.45em;
		height: 0.45em;
		border-right: 1.5px solid currentColor;
		border-bottom: 1.5px solid currentColor;
		transform: rotate(45deg);
		transform-origin: center;
		transition:
			transform 150ms ease,
			color 150ms ease,
			opacity 150ms ease;
		opacity: 0.7;
		color: var(--muted);
	}

	.timeline-era[open] > .timeline-era__summary .chevron {
		transform: rotate(225deg);
		color: color-mix(in srgb, var(--accent) 55%, var(--fg));
		opacity: 1;
	}

	.timeline-era > ol {
		list-style: none;
		margin: 0;
		padding: 0;
		border-left: 1px solid var(--border);
	}

	.timeline-era > ol > li {
		display: grid;
		grid-template-columns: 5.5rem 1fr;
		gap: 1rem;
		padding: 0 0 1.25rem 1.25rem;
		position: relative;
	}

	.timeline-era > ol > li:last-child {
		padding-bottom: 0;
	}

	.timeline-era > ol > li::before {
		content: "";
		position: absolute;
		left: -3.5px;
		top: 0.55em;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--accent);
	}

	.timeline .year-group {
		display: block;
		padding-bottom: 1.25rem;
	}

	.timeline .year-group:last-child {
		padding-bottom: 0;
	}

	.timeline .year-group::before {
		top: 0.55em;
	}

	.timeline .year-group > details {
		margin: 0;
	}

	.timeline .year-group > details > summary {
		display: grid;
		grid-template-columns: 5.5rem 1fr;
		gap: 1rem;
		cursor: pointer;
		list-style: none;
		border-radius: 0.2rem;
	}

	.timeline .year-group > details > summary::-webkit-details-marker {
		display: none;
	}

	.timeline .year-group > details > summary:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 3px;
	}

	.timeline summary .overview {
		display: flex;
		align-items: flex-start;
		gap: 0.5rem;
		transition: color 150ms ease;
	}

