---
import { Image } from "astro:assets";
import videoIcon from "@tabler/icons/outline/video.svg?raw";
import linkedinIcon from "@tabler/icons/outline/brand-linkedin.svg?raw";
import telegramIcon from "@tabler/icons/outline/brand-telegram.svg?raw";
import ProjectsGallery from "../components/ProjectsGallery.astro";
import {
	formatTimelineDate,
	timelineDateTime,
} from "../lib/format-timeline-date";
import portrait from "../assets/roman.jpg";

const name = "Roman Tikhonov";
const bio =
	"Product Manager leading Onboarding and Identity at payme (TBC Uzbekistan), a payment app with millions of users. Former cognitive science researcher at Carnegie Mellon with a PhD in Cognitive Psychology from St. Petersburg University.";
const description = `${name} — ${bio}`;
const canonicalUrl = new URL("/", Astro.site).href;
// Dedicated public asset so social crawlers are not blocked by the
// portrait AI-training opt-out on `/_astro/roman*`.
const ogImageUrl = new URL("/og.jpg", Astro.site).href;
const ogImageAlt = `${name} portrait`;

/** Tabler Icons (MIT) — https://tabler.io/icons
 *  Contact hrefs and handles are base64-obfuscated so static scrapers /
 *  LLM crawls do not see clear URLs or handles; humans get them via a
 *  tiny client script.
 */
const links = [
	{
		prefix: "LinkedIn:",
		label: "LinkedIn",
		labelEnc: Buffer.from("/in/romantikhonov", "utf8").toString("base64"),
		hrefEnc: Buffer.from(
			"https://www.linkedin.com/in/romantikhonov/",
			"utf8",
		).toString("base64"),
		icon: linkedinIcon,
	},
	{
		prefix: "Telegram:",
		label: "Telegram",
		labelEnc: Buffer.from("@rvtikhonov", "utf8").toString("base64"),
		hrefEnc: Buffer.from("https://t.me/rvtikhonov", "utf8").toString(
			"base64",
		),
		icon: telegramIcon,
	},
	{
		prefix: "Meet:",
		label: "15 min call",
		labelEnc: undefined,
		hrefEnc: Buffer.from("https://cal.com/tikhonov/15-min-chat", "utf8").toString(
			"base64",
		),
		icon: videoIcon,
	},
];

const timeline = [
	{
		year: "2026-04",
		text: "Mentored teams at the Cursor hackathon (TBC Uzbekistan / payme). Helped choose and validate product ideas.",
	},
	{
		year: "2025",
		text: "Joined payme (TBC Uzbekistan) as Product Owner, later Product Manager. Own Onboarding and Identity. Tashkent.",
	},
	{
		year: "2024",
		text: "Co-founded ReviewLab.app, a product feedback platform. Shipped MVP in 2.5 months.",
	},
	{
		year: "2023-11",
		text: "Published in MIT's Open Mind: Prediction, Explanation, and Control — mental models in dynamic environments.",
	},
	{
		year: "2023",
		text: "Moved into product management: PM at HumanteQ (mental health tech).",
	},
	{
		year: "2022",
		text: "Postdoctoral Fellow at Carnegie Mellon University, Pittsburgh. Studied how people learn complex patterns.",
	},
	{
		year: "2021",
		text: 'Researcher at JetBrains Research. PhD in Psychology, St. Petersburg University. "Best Teacher" award at HSE University.',
	},
	{
		year: "2018",
		text: "Lecturer, then Senior Lecturer at HSE University, St. Petersburg. Designed 4 award-winning courses.",
	},
	{
		year: "2016",
		text: "Market Research Analyst at UsabilityLab: ranked 700+ features across 16 mobile banking apps.",
	},
	{
		year: "2015",
		text: "Master's in Cognitive Psychology (with distinction). Started 7 years as a researcher at St. Petersburg University; co-authored 20+ peer-reviewed papers.",
	},
	{
		year: "2013",
		text: "Bachelor's in Psychology, St. Petersburg University.",
	},
	{
		year: "2012",
		text: "Exchange semester at the University of Eastern Finland.",
	},
	{
		year: "2010",
		text: "Led a human rights education project at AIESEC with 14 international volunteers.",
	},
	{
		year: "2009",
		text: "Finished vocational training in web development; started studying psychology.",
	},
	{
		year: "1992-05",
		text: "Born in Kryvyi Rih, Ukraine.",
	},
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta
			name="theme-color"
			content="#fafafa"
			media="(prefers-color-scheme: light)"
		/>
		<meta
			name="theme-color"
			content="#111"
			media="(prefers-color-scheme: dark)"
		/>
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:title" content={name} />
		<meta property="og:description" content={bio} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:alt" content={ogImageAlt} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={name} />
		<meta name="twitter:description" content={bio} />
		<meta name="twitter:image" content={ogImageUrl} />
		<meta name="twitter:image:alt" content={ogImageAlt} />
		<meta name="generator" content={Astro.generator} />
		<title>{name}</title>
	</head>
	<body>
		<main>
			<header>
				<span class="portrait-frame">
					<Image
						src={portrait}
						alt={ogImageAlt}
						width={140}
						height={140}
						densities={[1, 2, 3]}
						quality={90}
						class="portrait"
					/>
				</span>
				<h1>{name}</h1>
				<p class="bio">{bio}</p>
				<nav data-nosnippet aria-label="Contact">
					{
						links.map((link) => (
							<a
								href="#"
								data-u={link.hrefEnc}
								data-l={link.labelEnc}
								rel="nofollow noopener noreferrer"
								class="contact-item contact-link"
							>
								<span
									class="nav-icon"
									aria-hidden="true"
									set:html={link.icon}
								/>
								{link.prefix && (
									<span class="contact-prefix">{link.prefix}</span>
								)}
								<span class="contact-link__label">{link.label}</span>
							</a>
						))
					}
				</nav>
				<script is:inline>
					(() => {
						const revealHref = (a) => {
							const enc = a.getAttribute("data-u");
							if (!enc) return;
							try {
								a.href = atob(enc);
							} catch {
								/* ignore */
							}
						};
						document.querySelectorAll("a.contact-link").forEach((a) => {
							const labelEnc = a.getAttribute("data-l");
							const labelEl = a.querySelector(".contact-link__label");
							if (labelEnc && labelEl) {
								try {
									labelEl.textContent = atob(labelEnc);
								} catch {
									/* ignore */
								}
							}
							a.addEventListener("pointerdown", () => revealHref(a), {
								once: true,
							});
							a.addEventListener("focus", () => revealHref(a), { once: true });
							a.addEventListener(
								"click",
								(e) => {
									revealHref(a);
									if (a.getAttribute("href") === "#") {
										e.preventDefault();
									} else {
										a.setAttribute("target", "_blank");
									}
								},
								{ once: true },
							);
						});
					})();
				</script>
			</header>

			<ProjectsGallery />

			<section class="timeline" aria-label="Timeline">
				<ol>
					{
						timeline.map((entry) => {
							const label = formatTimelineDate(entry.year);
							const datetime = timelineDateTime(entry.year);
							return (
								<li>
									<span class="year">
										{datetime ? (
											<time datetime={datetime}>{label}</time>
										) : (
											label
										)}
									</span>
									<span class="event">{entry.text}</span>
								</li>
							);
						})
					}
				</ol>
			</section>
		</main>
		<script>
			import "../scripts/tilt";
		</script>
	</body>
</html>

<style is:global>
	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	:root {
		color-scheme: light dark;
		--bg: #fafafa;
		--fg: #111;
		--muted: #555;
		--border: #ddd;
		--link: #111;
		--link-hover: #555;
		--accent: #e35d05;
		--accent-fg: #fff;
		--font-mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
	}

	@media (prefers-color-scheme: dark) {
		:root {
			--bg: #111;
			--fg: #f5f5f5;
			--muted: #aaa;
			--border: #333;
			--link: #f5f5f5;
			--link-hover: #aaa;
			--accent: #f59a56;
			--accent-fg: #111;
		}
	}

	html {
		font-family:
			system-ui,
			-apple-system,
			BlinkMacSystemFont,
			"Segoe UI",
			Roboto,
			Helvetica,
			Arial,
			sans-serif;
		line-height: 1.5;
		background: var(--bg);
		color: var(--fg);
		overflow-x: clip;
	}

	body {
		margin: 0;
		min-height: 100dvh;
		display: flex;
		justify-content: center;
		padding: 3rem 1.5rem;
		overflow-x: clip;
	}

	main {
		max-width: 38rem;
		width: 100%;
	}

	header {
		margin-bottom: 3rem;
	}

	.portrait-frame {
		display: block;
		position: relative;
		width: 140px;
		height: 140px;
		border-radius: 50%;
		clip-path: circle(50%);
		margin: 0 0 1.25rem;
		overflow: hidden;
		isolation: isolate;
	}

	/* Holographic sheen: a diagonal streak that sweeps down once per
	   hover. No cursor tracking, no glow. */
	.portrait-frame::before {
		content: "";
		position: absolute;
		inset: -60% 0;
		z-index: 1;
		pointer-events: none;
		opacity: 0;
		background: linear-gradient(
			115deg,
			transparent 38%,
			color-mix(in srgb, #fff 36%, transparent) 48%,
			color-mix(in srgb, var(--accent) 26%, transparent) 54%,
			transparent 64%
		);
		mix-blend-mode: soft-light;
		transform: translateY(-35%);
	}

	.portrait {
		display: block;
		width: 100%;
		height: 100%;
		border-radius: 50%;
		object-fit: cover;
	}

	@media (hover: hover) and (pointer: fine) {
		.portrait-frame {
			transition: transform 250ms cubic-bezier(0.22, 1, 0.36, 1);
		}

		.portrait-frame:hover {
			transform: scale(1.03);
		}

		.portrait-frame:hover::before {
			animation: holo-sweep 700ms ease-out;
		}
	}

	@keyframes holo-sweep {
		0% {
			opacity: 0;
			transform: translateY(-35%);
		}
		35% {
			opacity: 1;
		}
		100% {
			opacity: 0;
			transform: translateY(35%);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.portrait-frame {
			transition: none;
		}

		.portrait-frame:hover {
			transform: none;
		}

		.portrait-frame:hover::before {
			animation: none;
		}
	}

	h1 {
		font-size: 2.4rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		margin: 0 0 0.75rem;
	}

	.bio {
		margin: 0 0 1.5rem;
		color: var(--muted);
	}

	nav {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.contact-item {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
	}

	.contact-prefix {
		color: var(--muted);
	}

	/* Prefix sheen: a diagonal highlight sweeps across the text once per
	   hover, echoing the portrait holo. Gradient is clipped to the glyphs. */
	@media (hover: hover) and (pointer: fine) {
		.contact-item:hover .contact-prefix {
			background: linear-gradient(
				115deg,
				var(--muted) 40%,
				color-mix(in srgb, #fff 45%, var(--muted)) 47%,
				color-mix(in srgb, var(--accent) 65%, var(--muted)) 53%,
				var(--muted) 60%
			);
			background-size: 300% 100%;
			background-position: 100% 0;
			-webkit-background-clip: text;
			background-clip: text;
			color: transparent;
			animation: prefix-sheen 700ms ease-out;
		}
	}

	@keyframes prefix-sheen {
		0% {
			background-position: 0% 0;
		}
		100% {
			background-position: 100% 0;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.contact-item:hover .contact-prefix {
			background: none;
			color: var(--muted);
			animation: none;
		}
	}

	/* The whole row is the anchor; only the label looks like a link. */
	nav a {
		color: inherit;
		text-decoration: none;
		border-radius: 0.2rem;
	}

	nav a:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 3px;
	}

	.contact-link__label {
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 0.2em;
		transition: color 150ms ease;
	}

	.contact-item:hover .contact-link__label,
	.contact-item:focus-visible .contact-link__label {
		color: color-mix(in srgb, var(--accent) 70%, var(--fg));
		text-decoration: none;
	}

	.nav-icon {
		display: inline-flex;
		width: 1.1em;
		height: 1.1em;
		flex-shrink: 0;
		color: var(--muted);
		transition: color 150ms ease;
	}

	.contact-item:hover .nav-icon,
	.contact-item:focus-visible .nav-icon {
		color: var(--accent);
	}

	.nav-icon svg {
		width: 100%;
		height: 100%;
		display: block;
	}

	.timeline ol {
		list-style: none;
		margin: 0;
		padding: 0;
		border-left: 1px solid var(--border);
	}

	.timeline li {
		display: grid;
		grid-template-columns: 5.5rem 1fr;
		gap: 1rem;
		padding: 0 0 1.25rem 1.25rem;
		position: relative;
	}

	.timeline li:last-child {
		padding-bottom: 0;
	}

	.timeline li::before {
		content: "";
		position: absolute;
		left: -3.5px;
		top: 0.55em;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--accent);
	}

	.year {
		font-family: var(--font-mono);
		font-variant-numeric: tabular-nums;
		font-size: 0.875rem;
		color: var(--muted);
		line-height: 1.5;
	}

	.event {
		font-size: 0.95rem;
		line-height: 1.5;
	}

	@media (max-width: 480px) {
		.timeline li {
			grid-template-columns: 1fr;
			gap: 0.25rem;
		}
	}
</style>
