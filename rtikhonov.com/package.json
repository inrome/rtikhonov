{
  "name": "rtikhonov.com",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "check:docs": "node ../scripts/check-docs.mjs",
    "build": "astro build",
    "preview": "astro build && NODE_OPTIONS=\"--dns-result-order=ipv4first\" wrangler dev",
    "deploy": "npm run check:docs && astro build && NODE_OPTIONS=\"--dns-result-order=ipv4first\" wrangler deploy",
    "astro": "astro"
  },
  "dependencies": {
    "@tabler/icons": "^3.45.0",
    "astro": "^7.1.1"
  },
  "devDependencies": {
    "wrangler": "^4.112.0"
  }
}
